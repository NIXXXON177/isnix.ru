# Скопируйте в social-publish.env (в .gitignore) или задайте секреты в GitHub.
# Не коммитьте токены.

# Discord: канал → Интеграции → Webhooks → URL
DISCORD_WEBHOOK_URL=

# Telegram: @BotFather → токен; бот — админ канала @isthisnixxxon
TELEGRAM_BOT_TOKEN=
# @isthisnixxxon или числовой id (-100…)
TELEGRAM_CHAT_ID=@isthisnixxxon

# ВК: Управление → Работа с API → Ключ доступа (Запись на стене)
VK_ACCESS_TOKEN=
# Числовой id группы (из адресной строки club123 → 123)
VK_GROUP_ID=
